# Environment variables for the Tennis Betting bot.
# Copy to secrets/.env and fill in REAL values:  cp .env.example secrets/.env
# secrets/ is gitignored — never commit it, and never paste these values into chat.

# --- Kalshi (v1) ---
KALSHI_KEY_ID=your-kalshi-key-id
KALSHI_PRIVATE_KEY_PATH=secrets/kalshi_private_key.pem

# --- Telegram alerts (v1) ---
TELEGRAM_TOKEN=your-botfather-token
TELEGRAM_CHAT_ID=your-chat-id

# --- Live-score feed (v2 only — not needed for v1 pre-match) ---
# LIVESCORE_API_KEY=your-api-tennis-key
